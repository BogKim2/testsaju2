{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/saju/api_analyze_request.schema.json",
  "title": "POST /api/saju/analyze request body",
  "type": "object",
  "required": ["gender", "birth_date", "calendar", "timezone"],
  "properties": {
    "name": { "type": ["string", "null"], "description": "Optional display name" },
    "gender": { "type": "string", "enum": ["male", "female"] },
    "birth_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "calendar": { "type": "string", "enum": ["solar", "lunar"] },
    "birth_time": {
      "type": ["string", "null"],
      "pattern": "^\\d{2}:\\d{2}$",
      "description": "HH:mm local time, or null if unknown"
    },
    "timezone": { "type": "string", "description": "IANA id e.g. Asia/Seoul" },
    "location": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
